From e6ca8ac3ebe31d25e5039c152a2d21aeeaf9c538 Mon Sep 17 00:00:00 2001
From: kay-lambdadelta <lambdadeltakay@proton.me>
Date: Tue, 14 Jul 2026 09:55:08 -0700
Subject: [PATCH] drm: panel: ch13726a: Add Retroid Pocket 5/mini panel support

---
 .../gpu/drm/panel/panel-chipwealth-ch13726a.c | 46 +++++++++++++++++++
 1 file changed, 46 insertions(+)

diff --git a/drivers/gpu/drm/panel/panel-chipwealth-ch13726a.c b/drivers/gpu/drm/panel/panel-chipwealth-ch13726a.c
index be76bc825c3f..8a202f067ccd 100644
--- a/drivers/gpu/drm/panel/panel-chipwealth-ch13726a.c
+++ b/drivers/gpu/drm/panel/panel-chipwealth-ch13726a.c
@@ -151,6 +151,34 @@ static const struct drm_display_mode thor_bottom_modes[] = {
 	}
 };
 
+static const struct drm_display_mode rp5_modes[] = {
+	{
+		.clock = (1080 + 12 + 4 + 12) * (1920 + 12 + 4 + 12) * 60 / 1000,
+		.hdisplay = 1080,
+		.hsync_start = 1080 + 12,
+		.hsync_end = 1080 + 12 + 4,
+		.htotal = 1080 + 12 + 4 + 12,
+		.vdisplay = 1920,
+		.vsync_start = 1920 + 12,
+		.vsync_end = 1920 + 12 + 4,
+		.vtotal = 1920 + 12 + 4 + 12,
+	},
+};
+
+static const struct drm_display_mode rpmini_modes[] = {
+	{
+		.clock = (960 + 28 + 4 + 36) * (1280 + 16 + 4 + 8) * 60 / 1000,
+		.hdisplay = 960,
+		.hsync_start = 960 + 28,
+		.hsync_end = 960 + 28 + 4,
+		.htotal = 960 + 28 + 4 + 36,
+		.vdisplay = 1280,
+		.vsync_start = 1280 + 16,
+		.vsync_end = 1280 + 16 + 4,
+		.vtotal = 1280 + 16 + 4 + 8,
+	},
+};
+
 static struct ch13726a_desc thor_bottom_desc = {
 	.modes = thor_bottom_modes,
 	.num_modes = ARRAY_SIZE(thor_bottom_modes),
@@ -159,6 +187,22 @@ static struct ch13726a_desc thor_bottom_desc = {
 	.bpc = 8,
 };
 
+static struct ch13726a_desc rp5_desc = {
+	.modes = rp5_modes,
+	.num_modes = ARRAY_SIZE(rp5_modes),
+	.width_mm = 68,
+	.height_mm = 121,
+	.bpc = 8,
+};
+
+static struct ch13726a_desc rpmini_desc = {
+	.modes = rpmini_modes,
+	.num_modes = ARRAY_SIZE(rpmini_modes),
+	.width_mm = 65,
+	.height_mm = 75,
+	.bpc = 8,
+};
+
 static int ch13726a_get_modes(struct drm_panel *panel,
 					struct drm_connector *connector)
 {
@@ -315,6 +359,8 @@ static void ch13726a_remove(struct mipi_dsi_device *dsi)
 
 static const struct of_device_id ch13726a_of_match[] = {
 	{ .compatible = "ayntec,thor-panel-bottom", .data = &thor_bottom_desc },
+	{ .compatible = "ch13726a,rp5", .data = &rp5_desc },
+	{ .compatible = "ch13726a,rpmini", .data = &rpmini_desc },
 	{ /* sentinel */ }
 };
 MODULE_DEVICE_TABLE(of, ch13726a_of_match);
-- 
2.53.0

